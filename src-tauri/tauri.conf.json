{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spive2d",
  "version": "0.1.1",
  "identifier": "com.lmmtrr.spive2d",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Spive2D",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "$DOWNLOAD/**",
            "$DESKTOP/**",
            "$DOCUMENT/**",
            "$PICTURE/**",
            "$TEMP/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}